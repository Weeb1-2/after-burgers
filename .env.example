# After Burgers - Ejemplo de Variables de Entorno
# Copia este archivo a .env y completa con tus credenciales reales

# Supabase Configuration
# Obtén estas credenciales de tu proyecto en supabase.com
SUPABASE_URL=tu_url_de_supabase_aqui
# Publishable key (recomendada) o anon legacy (eyJ...) desde Supabase → Settings → API
SUPABASE_ANON_KEY=sb_publishable_tu_clave_aqui

# Admin Configuration
# Contraseña para acceder al panel de administración y cocina
ADMIN_PASSWORD=tu_contraseña_aqui

# WhatsApp Configuration
# Número de teléfono con código de país (sin el +)
# Ejemplo Argentina: 549 + código de área + número
WHATSAPP_NUMBER=tu_numero_de_whatsapp_aqui

# Horarios (formato 24h)
# Hora de apertura (ej: 21 = 9 PM)
OPENING_HOUR=21
# Hora de cierre (ej: 3 = 3 AM)
CLOSING_HOUR=3

# Supabase Storage Bucket para imágenes
# Crea un bucket público en Supabase Storage con este nombre
STORAGE_BUCKET=productos-imagenes